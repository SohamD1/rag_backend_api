APP_ENV=production
APP_LOG_LEVEL=INFO

# Auth (recommended in production)
# If KB_REQUIRE_AUTH=true:
# - `/api/v1/chat*` requires `Authorization: Bearer <KB_APP_TOKEN>`
# - `/api/v1/documents*` requires `Authorization: Bearer <KB_ADMIN_TOKEN>`
KB_REQUIRE_AUTH=true
KB_APP_TOKEN=
KB_ADMIN_TOKEN=

# Rate limiting
# - When KB_REQUIRE_AUTH=true and X-Friedmann-User-Id is provided, chat limiting keys per advisor id.
# - If auth is disabled or invalid, limiting falls back to per-IP.
RAG_CHAT_RPM=120
RAG_CHAT_BURST=30
RAG_ADMIN_RPM=30
RAG_ADMIN_BURST=10

# Security: only trust X-Forwarded-For when behind a trusted proxy
RAG_TRUST_X_FORWARDED_FOR=false

# Memory safety for in-process rate limiter
RAG_RATE_LIMIT_MAX_BUCKETS=10000
RAG_RATE_LIMIT_BUCKET_TTL_SECONDS=3600

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=90
OPENAI_MAX_RETRIES=1

# Models
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Batch size for embedding API calls (helps with large documents).
OPENAI_EMBEDDING_BATCH_SIZE=128
# Optional: only set this if your Pinecone index was created with a smaller dimension.
OPENAI_EMBEDDING_DIMENSIONS=
OPENAI_GENERATION_MODEL=gpt-5.4-nano-2026-03-17
OPENAI_GENERATION_MAX_COMPLETION_TOKENS=1400
OPENAI_TREE_MODEL=gpt-5.4-nano-2026-03-17
OPENAI_TREE_REASONING_EFFORT=high
OPENAI_TREE_SEARCH_MODEL=gpt-5.4-nano-2026-03-17
OPENAI_REWRITE_MODEL=gpt-5-mini-2025-08-07

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX=rag-backend
PINECONE_HOST=
PINECONE_TIMEOUT_SECONDS=30
PINECONE_UPSERT_BATCH_SIZE=100

# Mistral OCR (required for PDF document ingestion; uploads always go through Mistral OCR)
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_OCR_TIMEOUT_SECONDS=120
MISTRAL_OCR_DELETE_UPLOADED_FILE=true
# Optional OCR tuning placeholders. Keep blank unless code/support explicitly requires them.
KB_OCR_MODE=auto
KB_OCR_MIN_CHARS_PER_PAGE=50
KB_OCR_MIN_TEXT_PAGE_RATIO=0.4

# Storage
DATA_DIR=./data
DOCS_DIR=
TREE_DIR=
LOCAL_STORAGE_DIR=
CACHE_DIR=./data/cache

# Routing
PAGE_TREE_THRESHOLD=20

# Standard chunking (token-based)
CHUNK_TARGET_TOKENS=420
CHUNK_MIN_TOKENS=320
CHUNK_MAX_TOKENS=520
CHUNK_OVERLAP_TOKENS=30
CHUNKING_LOGIC_VERSION=v3_heading_aware

# Doc selection via multi-vector doc summaries
DOC_SUMMARY_NAMESPACE=__doc_summaries
DOC_SUMMARY_TOP_K=7
DOC_SUMMARY_MATCH_TOP_K=12
DOC_SUMMARY_STRATEGY_VERSION=multi_vector_v1
DOC_STRONG_MIN_SCORE=0.35
DOC_STRONG_MIN_RATIO=1.15
DOC_REWRITE_MAX_ATTEMPTS=0

# Retrieval / rerank / context
RETRIEVE_TOP_K=30
RERANK_CANDIDATE_K=24
RERANK_TOP_K=6
MAX_CONTEXT_TOKENS=4200
CONTEXT_MAX_ITEM_TOKENS=850
LOW_CONFIDENCE_THRESHOLD=0.35
CONTEXT_USE_MMR=true
CONTEXT_MMR_LAMBDA=0.7
# Feature flag: when false, skip final LLM answer and return retrieved chunks only.
RAG_GENERATE_ANSWERS_ENABLED=false

# Tree indexing + retrieval (PageIndex-style caps)
TOC_CHECK_PAGE_NUM=12
MAX_PAGES_PER_NODE=10
MAX_TOKENS_PER_NODE=10000
OVERLAP_PAGES=1
TREE_SECTION_TOP_K=12
TREE_PAGEINDEX_TOC_ENABLED=true
TREE_VERIFY_TOC_ENABLED=true
TREE_VERIFY_TOC_MAX_ITEMS=20
TREE_FIX_TOC_ENABLED=true
TREE_FIX_TOC_MAX_ATTEMPTS=2
TREE_FIX_TOC_WINDOW_PAGES=8
TREE_SPLIT_LARGE_NODES_ENABLED=true
TREE_SPLIT_LARGE_NODES_MAX_DEPTH=2
TREE_NODE_SUMMARIES_ENABLED=true
TREE_NODE_SUMMARY_MAX_TOKENS=1200
TREE_NODE_SUMMARY_TOKEN_THRESHOLD=200
TREE_NODE_SUMMARY_MAX_WORKERS=4
TREE_NODE_SUMMARY_MAX_NODES=200

# Tree retrieval: hybrid node selection
TREE_NODE_SELECTION_MODE=vector_then_llm  # vector_only | vector_then_llm | llm_then_vector
TREE_NODE_SELECTION_CANDIDATE_K=12
TREE_NODE_SELECTION_TOP_N=4
TREE_NODE_SELECTION_MAX_TREE_NODES=80

# Debugging / SSE
RAG_DEBUG=false
RAG_LOG_PAYLOADS=false
RAG_LOG_CHAT_ANSWER=false
RAG_LOG_PAYLOAD_MAX_CHARS=8000
SSE_HEARTBEAT_SECONDS=15

# Scripts
KB_API_BASE_URL=http://localhost:8000

# Versioning (bump to force a rebuild/reindex when chunking or tree logic changes)
INDEX_SCHEMA_VERSION=v4
